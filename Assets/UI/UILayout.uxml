<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label text="Score: 0" name="ScoreLabel" emoji-fallback-support="false" style="top: 20px; align-self: center; font-size: 20px; -unity-text-align: upper-center; color: rgb(255, 255, 255); -unity-font-style: bold;"/>
    <ui:Button text="Restart" name="RestartButton" style="top: 50%; position: absolute; align-self: center; border-left-width: 1px; border-bottom-left-radius: 20px; border-top-left-radius: 20px; border-top-right-radius: 20px; border-bottom-right-radius: 20px;"/>
    <ui:Label text="High Score: " name="HighScoreLabel" style="align-self: center; color: rgb(255, 255, 255); -unity-text-align: upper-center; -unity-text-outline-width: 0; letter-spacing: 0; border-left-width: 1px; border-top-width: 1px; border-right-width: 1px; border-bottom-width: 1px; border-left-color: rgb(140, 140, 140); border-right-color: rgb(140, 140, 140); border-top-color: rgb(140, 140, 140); border-bottom-color: rgb(140, 140, 140); background-color: rgba(70, 70, 70, 0.47); border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; font-size: 16px; opacity: 1; top: 10px;"/>
</ui:UXML>
